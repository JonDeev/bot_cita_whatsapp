# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SISM legacy MySQL production connection
# IMPORTANT: use read-only credentials whenever possible.
SISM_DATABASE_URL=mysql://replace_user:replace_password@replace_host:3306/replace_database
SISM_MYSQL_HOST=replace_host
SISM_MYSQL_PORT=3306
SISM_MYSQL_USER=replace_user
SISM_MYSQL_PASSWORD=replace_password
SISM_MYSQL_DATABASE=replace_database

# Legacy compatibility alias (optional)
DATABASE_URL=mysql://replace_user:replace_password@replace_host:3306/replace_database

# WhatsApp bot MySQL persistence
# IMPORTANT: this must be a separate database from the clinical SISM schema.
BOT_DATABASE_NAME=whatsapp_bot
BOT_DATABASE_URL=mysql://whatsapp_bot_app:replace_password@replace_host:3306/whatsapp_bot?allowPublicKeyRetrieval=true
BOT_MIGRATION_DATABASE_URL=mysql://whatsapp_bot_migrator:replace_password@replace_host:3306/whatsapp_bot?allowPublicKeyRetrieval=true

# One-time DBA bootstrap only. Do not configure these in runtime containers.
MYSQL_ADMIN_HOST=replace_host
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USER=replace_admin_user
MYSQL_ADMIN_PASSWORD=replace_admin_password
BOT_DATABASE_APP_USER=whatsapp_bot_app
BOT_DATABASE_APP_PASSWORD=replace_strong_app_password
BOT_DATABASE_MIGRATION_USER=whatsapp_bot_migrator
BOT_DATABASE_MIGRATION_PASSWORD=replace_strong_migration_password

# DB write guardrail (must stay false by default in production)
ALLOW_AGENDA_UPDATES=false
ALLOW_LEGACY_PATIENT_CONTACT_WRITE=false
SISM_CONTACT_WRITE_DATABASE_URL=mysql://replace_contact_writer:replace_password@replace_host:3306/replace_database

# Redis
REDIS_URL=redis://localhost:6379
CONVERSATION_SESSION_TTL_SECONDS=86400
WHATSAPP_RESTORE_SESSION_FROM_PERSISTENCE=true

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_me
WHATSAPP_APP_SECRET=replace_me
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_STORE_WEBHOOK_PAYLOADS=true
WHATSAPP_INTERACTIVE_EVENT_MAX_AGE_SECONDS=900
WHATSAPP_TEXT_EVENT_MAX_AGE_SECONDS=86400
CONVERSATION_IDLE_POLICY_ENABLED=true
CONVERSATION_IDLE_REMINDER_MINUTES=15
CONVERSATION_IDLE_EXPIRE_MINUTES=20
CONVERSATION_IDLE_POLICY_TICK_INTERVAL_MS=60000
CONVERSATION_IDLE_POLICY_BATCH_SIZE=100
CONVERSATION_IDLE_POLICY_LOCK_TTL_SECONDS=55
WHATSAPP_SURVEY_FLOW_TEMPLATE_NAME=replace_me
WHATSAPP_SURVEY_FLOW_TEMPLATE_LANGUAGE_CODE=es_CO
WHATSAPP_SURVEY_FLOW_TEMPLATE_BUTTON_INDEX=0
SURVEYS_HALF_HOURLY_DISPATCH_ENABLED=false
SURVEYS_HALF_HOURLY_DISPATCH_INTERVAL_MS=60000
SURVEYS_HALF_HOURLY_DISPATCH_LOCK_TTL_SECONDS=2100
SURVEYS_ELIGIBILITY_SOURCE=legacy
SURVEYS_ELIGIBILITY_JSON_FILE_PATH=ops/fixtures/surveys/eligibility-test.json
SURVEY_FLOW_FIELD_DECISION=survey_decision
SURVEY_FLOW_FIELD_Q1=q1
SURVEY_FLOW_FIELD_Q2=q2
SURVEY_FLOW_FIELD_Q3=q3
SURVEY_FLOW_FIELD_Q4=q4
SURVEY_FLOW_FIELD_Q5_COMMENT=q5_comment
INTERNAL_SURVEYS_METRICS_TOKEN=replace_me

# Appointment reminders
APPOINTMENT_REMINDERS_SYNC_ENABLED=false
APPOINTMENT_REMINDERS_DISPATCH_ENABLED=false
APPOINTMENT_REMINDERS_QUEUE_ENABLED=true
APPOINTMENT_REMINDERS_SYNC_INTERVAL_MS=300000
APPOINTMENT_REMINDERS_DISPATCH_INTERVAL_MS=60000
APPOINTMENT_REMINDERS_RECOVERY_SWEEP_INTERVAL_MS=300000
APPOINTMENT_REMINDERS_QUEUE_NAME=appointment-reminders-dispatch
APPOINTMENT_REMINDERS_WORKER_CONCURRENCY=1
APPOINTMENT_REMINDERS_ELIGIBILITY_LIMIT=500
APPOINTMENT_REMINDERS_DISPATCH_BATCH_SIZE=50
APPOINTMENT_REMINDERS_RECOVERY_BATCH_SIZE=200
APPOINTMENT_REMINDERS_ELIGIBILITY_WINDOW_HOURS=72
APPOINTMENT_REMINDERS_LOCK_TTL_SECONDS=300
APPOINTMENT_REMINDERS_LOCK_HEARTBEAT_INTERVAL_MS=60000
APPOINTMENT_REMINDERS_MIN_CONFIRMATION_HOURS=3
APPOINTMENT_REMINDERS_TIMEZONE=America/Bogota
APPOINTMENT_REMINDERS_BUTTON_SIGNING_SECRET=replace_me
WHATSAPP_APPOINTMENT_REMINDER_TEMPLATE_NAME=recordatorio_cita_24h
WHATSAPP_APPOINTMENT_REMINDER_VERIFICATION_TEMPLATE_NAME=verificacion_telefono_paciente
WHATSAPP_APPOINTMENT_REMINDER_TEMPLATE_LANGUAGE_CODE=es_CO
INTERNAL_REMINDERS_METRICS_TOKEN=replace_me

# Admin auth bootstrap and security
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_DISPLAY_NAME=Admin SISM
ADMIN_BOOTSTRAP_ROLE=ADMIN
ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_secret
ADMIN_BOOTSTRAP_ALLOW_UPDATE=false
ADMIN_AUTH_SESSION_COOKIE_NAME=__Host-sism_admin_session
ADMIN_AUTH_SESSION_TTL_HOURS=12
ADMIN_AUTH_COOKIE_SECURE=true
ADMIN_AUTH_LOGIN_THROTTLE_WINDOW_SECONDS=900
ADMIN_AUTH_LOGIN_MAX_ATTEMPTS_PER_IP=30
ADMIN_AUTH_LOGIN_MAX_ATTEMPTS_PER_IDENTIFIER=10
ADMIN_AUTH_ARGON2_PASSES=3
ADMIN_AUTH_ARGON2_MEMORY_KIB=65536
ADMIN_AUTH_ARGON2_PARALLELISM=1
ADMIN_AUTH_ARGON2_TAG_LENGTH=32
# Pre-generated anti-enumeration hash. Required in production.
# Generate with: pnpm admin:auth:dummy-hash
ADMIN_AUTH_DUMMY_PASSWORD_HASH=replace_with_dummy_hash
ADMIN_OVERVIEW_LOOKBACK_HOURS=24
ADMIN_LIVE_FEED_LIMIT=50
