# App
NODE_ENV=development
PORT=3000

# SISM legacy MySQL production connection
# IMPORTANT: use read-only credentials whenever possible.
SISM_DATABASE_URL=mysql://replace_user:replace_password@replace_host:3306/replace_database
SISM_MYSQL_HOST=replace_host
SISM_MYSQL_PORT=3306
SISM_MYSQL_USER=replace_user
SISM_MYSQL_PASSWORD=replace_password
SISM_MYSQL_DATABASE=replace_database

# Legacy compatibility alias (optional)
DATABASE_URL=mysql://replace_user:replace_password@replace_host:3306/replace_database

# WhatsApp bot MySQL persistence
# IMPORTANT: this must be a separate database from the clinical SISM schema.
BOT_DATABASE_NAME=whatsapp_bot
BOT_DATABASE_URL=mysql://whatsapp_bot_app:replace_password@replace_host:3306/whatsapp_bot?allowPublicKeyRetrieval=true
BOT_MIGRATION_DATABASE_URL=mysql://whatsapp_bot_migrator:replace_password@replace_host:3306/whatsapp_bot?allowPublicKeyRetrieval=true

# One-time DBA bootstrap only. Do not configure these in runtime containers.
MYSQL_ADMIN_HOST=replace_host
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USER=replace_admin_user
MYSQL_ADMIN_PASSWORD=replace_admin_password
BOT_DATABASE_APP_USER=whatsapp_bot_app
BOT_DATABASE_APP_PASSWORD=replace_strong_app_password
BOT_DATABASE_MIGRATION_USER=whatsapp_bot_migrator
BOT_DATABASE_MIGRATION_PASSWORD=replace_strong_migration_password

# DB write guardrail (must stay false by default in production)
ALLOW_AGENDA_UPDATES=false

# Redis
REDIS_URL=redis://localhost:6379
CONVERSATION_SESSION_TTL_SECONDS=86400
WHATSAPP_RESTORE_SESSION_FROM_PERSISTENCE=true

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_me
WHATSAPP_APP_SECRET=replace_me
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_STORE_WEBHOOK_PAYLOADS=true
WHATSAPP_INTERACTIVE_EVENT_MAX_AGE_SECONDS=900
WHATSAPP_TEXT_EVENT_MAX_AGE_SECONDS=86400
