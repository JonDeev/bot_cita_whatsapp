{
  "name": "adriana",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:bot:up": "docker-compose --env-file .env.bot-db -f docker-compose.bot-db.yml up -d",
    "db:bot:down": "docker-compose --env-file .env.bot-db -f docker-compose.bot-db.yml down",
    "db:bot:ps": "docker-compose --env-file .env.bot-db -f docker-compose.bot-db.yml ps",
    "db:create:whatsapp-bot": "node scripts/database/create-whatsapp-bot-database.js",
    "prisma:bot:format": "prisma format --schema prisma/bot/schema.prisma --config prisma.bot.config.ts",
    "prisma:bot:validate": "prisma validate --schema prisma/bot/schema.prisma --config prisma.bot.config.ts",
    "prisma:bot:generate": "prisma generate --schema prisma/bot/schema.prisma --config prisma.bot.config.ts",
    "prisma:bot:migrate:dev": "prisma migrate dev --schema prisma/bot/schema.prisma --config prisma.bot.config.ts",
    "prisma:bot:migrate:deploy": "prisma migrate deploy --schema prisma/bot/schema.prisma --config prisma.bot.config.ts",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:pull": "prisma db pull",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ioredis": "^5.10.1",
    "mariadb": "^3.5.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
